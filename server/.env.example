# Port to run the server on
PORT=5000

# SMTP configuration (default is Gmail, but works with Resend, Outlook, SendGrid, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

# Your email authentication details
# For Gmail, you MUST use an "App Password" (not your login password).
# See: https://support.google.com/accounts/answer/185833
SMTP_USER=your-email@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx

# Destination email (where you want to receive the messages)
RECEIVER_EMAIL=your-destination-email@gmail.com
